# Copy file này thành .env (hoặc set từng biến trong môi trường / IDE)
# Supabase: Dashboard → Project Settings → API

# Database (đã có sẵn trong application.yml, chỉ cần sửa nếu đổi project)
# SUPABASE_DB_URL=jdbc:postgresql://xxx.pooler.supabase.com:5432/postgres?sslmode=require
# SUPABASE_DB_USERNAME=postgres.xxxxx
# SUPABASE_DB_PASSWORD=your-password

# Storage – bắt buộc để upload file lên Supabase (thay placeholder)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=data-items

# Tùy chọn
# SERVER_PORT=8080
# APP_BASE_URL=http://localhost:8080
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=10MB
# JWT_SECRET=your-256-bit-secret
# JWT_EXPIRATION=86400000
